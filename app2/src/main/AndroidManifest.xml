<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="luyao.android2">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name=".TaskActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".SingleTaskActivityX"
            android:exported="true"
            android:label="SingleTaskActivityX"
            android:launchMode="singleTop" />
        <activity
            android:name=".SingleTaskActivityY"
            android:exported="true"
            android:label="SingleTaskActivityY"
            android:launchMode="singleTop" />

        <activity
            android:name=".StandardActivityE"
            android:label="StandardActivityE" />

        <activity
            android:name=".StandardActivityF"
            android:exported="true"
            android:label="StandardActivityF" />

        <activity android:name=".AllowTaskReparentingActivity"
            android:exported="true"
            android:label="AllowTaskReparentingActivity"
            android:allowTaskReparenting="true"/>
    </application>
</manifest>